{
  "doctype": "DocType",
  "name": "Level Exam Paper",
  "module": "Custom",
  "custom": 1,
  "autoname": "format:LEP-{#####}",
  "document_type": "Document",
  "engine": "InnoDB",
  "field_order": [
    "paper_title",
    "subject",
    "class_level",
    "duration_minutes",
    "instructions",
    "total_questions",
    "total_marks",
    "status",
    "questions"
  ],
  "fields": [
    { "fieldname": "paper_title", "fieldtype": "Data", "label": "Paper Title", "reqd": 1 },
    { "fieldname": "subject", "fieldtype": "Data", "label": "Subject", "reqd": 1 },
    { "fieldname": "class_level", "fieldtype": "Select", "label": "Class Level", "options": "8\n9\n10", "reqd": 1 },
    { "fieldname": "duration_minutes", "fieldtype": "Int", "label": "Duration Minutes", "reqd": 1, "default": "20" },
    { "fieldname": "instructions", "fieldtype": "Small Text", "label": "Instructions" },
    { "fieldname": "total_questions", "fieldtype": "Int", "label": "Total Questions", "read_only": 1 },
    { "fieldname": "total_marks", "fieldtype": "Int", "label": "Total Marks", "read_only": 1 },
    { "fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nPublished\nArchived", "default": "Draft", "reqd": 1 },
    { "fieldname": "questions", "fieldtype": "Table", "label": "Questions", "options": "Level Exam Paper Question", "reqd": 1 }
  ],
  "permissions": [
    { "role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1 }
  ]
}
